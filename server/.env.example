# Railway / local Node extraction API (no VITE_ prefix).
# Copy to server/.env for local API dev in Phase 1+.

SUPABASE_URL=
SUPABASE_ANON_KEY=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

PORT=3000
LOG_LEVEL=info
PROMPT_VERSION=1

# Comma-separated origins allowed for CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
