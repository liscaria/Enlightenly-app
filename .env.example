# Copy this file to `.env.local` and fill in your real Supabase values.
# `.env.local` is git-ignored.

# The project URL from Supabase -> Project Settings -> API
VITE_SUPABASE_URL=

# Publishable key (sb_publishable_...) or legacy anon key (eyJ...) from the same page
VITE_SUPABASE_ANON_KEY=

# Name of the Storage bucket that will hold uploaded files.
# Defaults to "materials" if unset.
VITE_SUPABASE_BUCKET=materials

# Question Bank exam papers (separate from chapter materials)
VITE_SUPABASE_QUESTION_PAPERS_BUCKET=question-papers

# Optional: AI question extraction from uploaded PDFs (OpenAI)
# VITE_OPENAI_API_KEY=
# VITE_OPENAI_MODEL=gpt-4o-mini

