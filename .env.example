# Optional: AI question extraction from uploaded PDFs (browser-only fallback).
# Not required when VITE_USE_EXTRACTION_API=true (Update question bank, Classify chapters,
# and syllabus KB build use the Railway API). Still needed for chapter material uploads
# in the library until that path is migrated.
# VITE_OPENAI_API_KEY=
# VITE_OPENAI_MODEL=gpt-4o-mini   # use gpt-4o for harder CBSE bilingual papers
# Edit few-shot examples in src/constants/extractionPrompt.js

# Railway extraction API (Phase 3+). When true, browser OpenAI key is not required for
# question bank update, chapter classification, or syllabus knowledge build.
# VITE_EXTRACTION_API_URL=https://your-service.up.railway.app
# VITE_USE_EXTRACTION_API=true
